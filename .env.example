# Copy this file to .env and fill in your Supabase project credentials.
# Find both under: Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Shared team password for the dashboard login gate. Anyone opening the
# dashboard must enter this. Change it before sharing the link; change
# it again to lock everyone out. If left unset, a default is used.
VITE_APP_PASSWORD=change-this-team-password
